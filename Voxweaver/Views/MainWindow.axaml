<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Voxweaver.ViewModels"
        x:Class="Voxweaver.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Voxweaver"
        Width="760" Height="640"
        MinWidth="560" MinHeight="400"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>
    <Style Selector="Border.bar">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
      <Setter Property="Padding" Value="12 8" />
    </Style>

    <Style Selector="Border.statusbar">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeBlackLowBrush}" />
      <Setter Property="Padding" Value="12 4" />
    </Style>

    <Style Selector="Border.dropzone">
      <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Margin" Value="32" />
      <Setter Property="Padding" Value="32" />
    </Style>
    <Style Selector="Border.dropzone.dragover">
      <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight3}" />
    </Style>

    <Style Selector="Border.phrasecard">
      <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Margin" Value="0 0 0 8" />
      <Setter Property="Padding" Value="14 10" />
    </Style>

    <Style Selector="TextBlock.valid">
      <Setter Property="Foreground" Value="MediumSeaGreen" />
    </Style>
    <Style Selector="TextBlock.invalid">
      <Setter Property="Foreground" Value="Tomato" />
    </Style>

    <Style Selector="Border.warning">
      <Setter Property="Background" Value="#2B2200" />
      <Setter Property="BorderBrush" Value="Orange" />
      <Setter Property="BorderThickness" Value="0 0 0 1" />
      <Setter Property="Padding" Value="12 6" />
    </Style>
  </Window.Styles>

  <DockPanel>

    <!-- Top bar -->
    <Border Classes="bar" DockPanel.Dock="Top">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <!-- Back to drop zone — visible once a file is loaded -->
        <Button Grid.Column="0"
                Content="&lt; Change File"
                Command="{Binding ChangeFileCommand}"
                IsVisible="{Binding HasFile}"
                Margin="0 0 10 0"
                ToolTip.Tip="Discard current file and load a new one" />

        <TextBlock Grid.Column="1"
                   Text="Voxweaver" FontSize="16" FontWeight="Bold"
                   VerticalAlignment="Center"/>

        <!-- Back to track selector — visible only when viewing phrases with multiple tracks -->
        <Button Grid.Column="2"
                Content="&lt; Change Track"
                Command="{Binding ChangeTrackCommand}"
                IsVisible="{Binding CanChangeTrack}"
                Margin="0 0 8 0"
                ToolTip.Tip="Go back and choose a different track" />

        <Button Grid.Column="3"
                Content="Export Notes for AI"
                Command="{Binding CopyAiSummaryCommand}"
                ToolTip.Tip="Copies phrase note-counts to clipboard for an AI lyrics prompt" />
      </Grid>
    </Border>

    <!-- Status bar + export button -->
    <Border Classes="statusbar" DockPanel.Dock="Bottom">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{Binding StatusMessage}"
                   FontSize="12" Opacity="0.8"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
        <Button Grid.Column="1"
                Content="Export to OpenUtau (.ustx)"
                Command="{Binding ExportUstxCommand}"
                Margin="8 0 0 0" />
      </Grid>
    </Border>

    <!-- Chord warning banner -->
    <Border Classes="warning" DockPanel.Dock="Top" IsVisible="{Binding ShowChordWarning}">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="Warning: Chords detected. Please ensure this is a monophonic melody line."
                   Foreground="Orange" VerticalAlignment="Center" />
        <Button Grid.Column="1" Content="X" Command="{Binding DismissChordWarningCommand}"
                Background="Transparent" Padding="6 2" />
      </Grid>
    </Border>

    <!-- Track selection panel -->
    <Border DockPanel.Dock="Top" IsVisible="{Binding ShowTrackSelector}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            Padding="12 10"
            BorderBrush="{DynamicResource SystemAccentColor}"
            BorderThickness="0 0 0 1">
      <StackPanel Spacing="8">
        <TextBlock Text="Multiple tracks found — select the vocal melody track:"
                   FontWeight="SemiBold" />
        <ComboBox ItemsSource="{Binding AvailableTracks}"
                  SelectedItem="{Binding SelectedTrack}"
                  MinWidth="300" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Use this track" Command="{Binding ConfirmTrackCommand}" />
          <Button Content="&lt; Change File" Command="{Binding ChangeFileCommand}" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- AI lyric pipeline panel (visible once phrases are loaded) -->
    <Border DockPanel.Dock="Top" IsVisible="{Binding ShowContent}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="0 0 0 1"
            Padding="12 10">
      <StackPanel Spacing="8">

        <!-- Row 1: theme input + action buttons -->
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" >
          <TextBlock Grid.Column="0" Text="Theme:" VerticalAlignment="Center" Margin="0 0 8 0" />
          <TextBox Grid.Column="1"
                   Text="{Binding AiTheme}"
                   PlaceholderText="e.g. Geopolitical operations, covert actions in Tokyo"
                   Margin="0 0 8 0" />
          <Button Grid.Column="2"
                  Content="Export Payload (JSON)"
                  Command="{Binding ExportAiPayloadCommand}"
                  Margin="0 0 8 0"
                  ToolTip.Tip="Save a JSON payload for the LLM (theme + syllable counts per phrase)" />
          <Button Grid.Column="3"
                  Content="Import Response (JSON)"
                  Command="{Binding ImportAiResponseCommand}"
                  ToolTip.Tip="Load the LLM's JSON response and apply lyrics to each phrase" />
        </Grid>

        <!-- Row 2: validation log (only shown when there are issues) -->
        <Border IsVisible="{Binding HasAiValidationIssues}"
                Background="#2B1000"
                BorderBrush="Tomato"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10 6">
          <StackPanel Spacing="4">
            <TextBlock Text="Syllable Mismatches — flagged for manual review:"
                       Foreground="Tomato" FontWeight="SemiBold" FontSize="12" />
            <TextBlock Text="{Binding AiValidationLog}"
                       Foreground="Tomato" FontSize="11" FontFamily="Monospace"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

      </StackPanel>
    </Border>

    <!-- Scrollable centre content -->
    <ScrollViewer Padding="16">
      <Panel>

        <!-- Drop zone (shown when no file is loaded) -->
        <Border Classes="dropzone"
                IsVisible="{Binding ShowDropZone}"
                Classes.dragover="{Binding IsDragOver}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center">
          <StackPanel HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="Drop a MIDI file here"
                       FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="(.mid or .midi)"
                       Opacity="0.6" HorizontalAlignment="Center" />
            <Button Content="Browse…"
                    HorizontalAlignment="Center"
                    Command="{Binding BrowseFileCommand}" />
          </StackPanel>
        </Border>

        <!-- Phrase list (shown once phrases are loaded) -->
        <ItemsControl ItemsSource="{Binding Phrases}"
                      IsVisible="{Binding ShowContent}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:PhraseViewModel">
              <Border Classes="phrasecard">
                <Grid ColumnDefinitions="80,80,*,120">

                  <TextBlock Grid.Column="0"
                             Text="{Binding Label}"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />

                  <TextBlock Grid.Column="1"
                             Text="{Binding NoteCountText}"
                             Opacity="0.6" FontSize="12"
                             VerticalAlignment="Center" />

                  <TextBox Grid.Column="2"
                           Text="{Binding Lyrics}"
                           PlaceholderText="Type lyrics for this phrase…"
                           Margin="8 0" />

                  <TextBlock Grid.Column="3"
                             Text="{Binding SyllableIndicator}"
                             Classes.valid="{Binding IsValid}"
                             Classes.invalid="{Binding IsNotValid}"
                             FontSize="12"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Right" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </Panel>
    </ScrollViewer>
  </DockPanel>
</Window>
